# RoboLab // Playlist Sync - Environment Variables
# All variables must be prefixed with ROBOLAB_

# App Configuration
ROBOLAB_REDIRECT_URI=http://localhost:8080

# Spotify Configuration
# Get your Client ID at https://developer.spotify.com/dashboard
ROBOLAB_SPOTIFY_CLIENT_ID=

# Google / YouTube Configuration
# Get your Client ID at https://console.cloud.google.com/
ROBOLAB_GOOGLE_CLIENT_ID=

# System API Keys (Optional, for read-only access if OAuth is not used)
# Note: Write operations on YouTube REQUIRE OAuth
ROBOLAB_SPOTIFY_API_KEY=
ROBOLAB_YOUTUBE_API_KEY=
