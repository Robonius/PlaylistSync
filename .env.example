# Playlist Sync Tool - Environment Configuration Example

# --- API Keys (Sensitive) ---
# These keys are injected at runtime in Docker and should NEVER be baked into the image.
# Do NOT prefix these with VITE_ if you want to ensure they are NOT baked by Vite.
SPOTIFY_API_KEY=your_spotify_api_key_here
YOUTUBE_API_KEY=your_youtube_api_key_here

# --- Application Settings ---
APP_NAME="Playlist Sync Tool"
VITE_LOG_LEVEL=info

# --- API Endpoints ---
# These can be baked if they are public, or injected at runtime.
VITE_SPOTIFY_API_URL=https://api.spotify.com/v1
VITE_YOUTUBE_API_URL=https://www.googleapis.com/youtube/v3
