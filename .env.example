# RoboLab // Playlist Sync - Environment Variables
# Using standard names (no prefix) for simplicity.
# Non-sensitive variables are shared with the browser via RuntimeConfigProvider.
# Sensitive variables (Client Secrets) stay server-side.

# App Configuration
REDIRECT_URI=http://localhost:8080

# Spotify Configuration
# Get your Client ID and Secret at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Google / YouTube Configuration
# Get your Client ID and Secret at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# System API Keys (Optional, for read-only access if OAuth is not used)
# Note: Write operations on YouTube REQUIRE OAuth
SPOTIFY_API_KEY=
YOUTUBE_API_KEY=
